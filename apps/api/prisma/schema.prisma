// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// PERFILES Y AUTENTICACIÓN
// ============================================

enum ProfileRole {
  master
  admin
  player
  photographer
  referee
  official
}

// Profile: Persona (con o sin cuenta). Stub sin supabaseUserId/email para lista de buena fe; al registrarse se asocia por DNI.
model Profile {
  id                 String    @id @default(uuid())
  supabaseUserId     String?   @unique
  email              String?   @unique
  name               String
  phone              String?   @unique
  phoneVerified      Boolean   @default(false)
  documentNumber     String?    @unique
  documentVerified   Boolean   @default(false)
  documentVerifiedBy String?
  documentVerifiedAt DateTime?
  dateOfBirth        DateTime?
  avatarUrl          String?
  role               ProfileRole   @default(player)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  franchisesOwned       Franchise[]
  teamsCreated          Team[]                @relation("TeamCreator")
  teamsCaptainOf        Team[]                @relation("TeamCaptain")
  teamMemberships       ProfileTeam[]
  matchRosters          MatchRoster[]
  assignedMatches       MatchStaff[]          @relation("AssignedBy")
  registrations         Registration[]        @relation("RequestedBy")
  approvedRegistrations Registration[]        @relation("ApprovedBy")
  payments              Payment[]
  matchAnnouncements    MatchAnnouncement[]

  @@map("profiles")
}

// ============================================
// DEPORTES, FRANQUICIAS Y EQUIPOS
// ============================================

model Sport {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams       Team[]
  tournaments Tournament[]

  @@map("sports")
}

model Franchise {
  id        String    @id @default(uuid())
  name      String
  logoUrl   String?
  ownerId   String
  owner     Profile   @relation(fields: [ownerId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  teams Team[]

  @@index([ownerId])
  @@map("franchises")
}

model Team {
  id          String    @id @default(uuid())
  name        String
  logoUrl     String?
  sportId     String
  sport       Sport     @relation(fields: [sportId], references: [id])
  franchiseId String?
  franchise   Franchise? @relation(fields: [franchiseId], references: [id])
  creatorId   String?
  creator     Profile?  @relation("TeamCreator", fields: [creatorId], references: [id])
  captainId   String?
  captain     Profile?  @relation("TeamCaptain", fields: [captainId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  members     ProfileTeam[]
  teamZones   TeamZone[]
  homeMatches Match[]        @relation("HomeTeam")
  awayMatches   Match[]        @relation("AwayTeam")
  registrations Registration[]

  @@index([franchiseId])
  @@map("teams")
}

model ProfileTeam {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id])
  position  String?
  joinedAt  DateTime @default(now())
  isActive  Boolean  @default(true)

  @@unique([profileId, teamId])
  @@index([profileId])
  @@index([teamId])
  @@map("player_teams")
}

// ============================================
// TORNEOS, CATEGORÍAS Y ZONAS
// ============================================

enum TournamentStatus {
  DRAFT
  OPEN
  CLOSED
  READY_TO_SHIP
  IN_PROGRESS
  FINISHED
  ARCHIVED
  CANCELLED
}

enum CategoryStatus {
  OPEN
  CLOSED
  IN_PROGRESS
  FINISHED
}

enum CategorySubstatus {
  REGULAR_FASE
  PLAYOFFS_FASE
}

model Tournament {
  id                    String           @id @default(uuid())
  name                  String
  slug                  String           @unique
  description           String?
  sportId               String
  sport                 Sport            @relation(fields: [sportId], references: [id])
  status                TournamentStatus @default(DRAFT)
  startDate             DateTime?
  endDate               DateTime?
  registrationStartDate DateTime?
  registrationEndDate   DateTime?
  insurancePerPlayer    Float?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?

  categories     Category[]
  registrations  Registration[]
  registrationPricing TournamentRegistrationPricing[]

  @@index([status])
  @@index([sportId])
  @@index([startDate])
  @@map("tournaments")
}

model TournamentRegistrationPricing {
  id          String    @id @default(uuid())
  tournamentId String
  tournament  Tournament @relation(fields: [tournamentId], references: [id])
  validFrom   DateTime
  validTo     DateTime
  entryFeeAmount Float
  currency    String    @default("ARS")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tournamentId])
  @@index([tournamentId, validFrom, validTo])
  @@map("tournament_registration_pricing")
}

model Category {
  id           String            @id @default(uuid())
  tournamentId String
  tournament   Tournament        @relation(fields: [tournamentId], references: [id])
  name         String
  maxTeams     Int?
  teamsPerZone Int?
  status       CategoryStatus    @default(OPEN)
  substatus    CategorySubstatus?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  zones         Zone[]
  matches       Match[]
  registrations Registration[]

  @@index([tournamentId])
  @@index([status])
  @@map("categories")
}

model Zone {
  id               String    @id @default(uuid())
  categoryId       String
  category         Category  @relation(fields: [categoryId], references: [id])
  name             String
  fixtureAlgorithm String? // round_robin, custom
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  teamZones TeamZone[]
  matches   Match[]

  @@index([categoryId])
  @@map("zones")
}

model TeamZone {
  id         String   @id @default(uuid())
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id])
  zoneId     String
  zone       Zone     @relation(fields: [zoneId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([teamId, zoneId])
  @@index([teamId])
  @@index([zoneId])
  @@map("team_zones")
}

// ============================================
// CANCHAS Y LOCACIONES
// ============================================

model Venue {
  id            String    @id @default(uuid())
  name          String
  address       String?
  city          String?
  province      String?
  country       String    @default("Argentina")
  googleMapsUrl String?
  capacity      Int?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  matches Match[]

  @@map("venues")
}

// ============================================
// PARTIDOS
// ============================================

model Match {
  id             String    @id @default(uuid())
  homeTeamId     String?
  homeTeam       Team?     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId     String?
  awayTeam       Team?     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  zoneId         String?
  zone           Zone?     @relation(fields: [zoneId], references: [id])
  venueId        String?
  venue          Venue?    @relation(fields: [venueId], references: [id])
  matchDate      DateTime
  matchTime      String?
  status         String
  matchType      String
  homeScore   Int     @default(0)
  awayScore   Int     @default(0)
  costPerTeam Float?
  createdAt   DateTime @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  matchStaff    MatchStaff[]
  roster        MatchRoster[]
  payments      Payment[]
  announcements MatchAnnouncement[]

  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([categoryId])
  @@index([zoneId])
  @@index([venueId])
  @@index([status])
  @@index([matchDate])
  @@index([status, matchDate])
  @@map("matches")
}

model MatchRoster {
  id          String   @id @default(uuid())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id])
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id])
  jerseyNumber Int
  createdAt   DateTime @default(now())

  @@unique([matchId, profileId])
  @@index([matchId])
  @@index([profileId])
  @@map("match_rosters")
}

model MatchAnnouncement {
  id        String   @id @default(uuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id])
  type      String // suspension, cancellation, reschedule, other
  title     String
  message   String
  createdBy String
  creator   Profile  @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now())

  @@index([matchId])
  @@map("match_announcements")
}

// ============================================
// PERSONAL (STAFF)
// ============================================

model Staff {
  id        String    @id @default(uuid())
  profileId String?   @unique // Opcional: vinculado a Profile si tiene cuenta
  type      String // referee, table_official, photographer
  firstName String
  lastName  String
  phone     String?
  email     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  availability StaffAvailability[]
  matchStaff   MatchStaff[]

  @@index([profileId])
  @@index([type])
  @@map("staff")
}

model StaffAvailability {
  id        String   @id @default(uuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id])
  dayOfWeek Int // 0=domingo, 6=sábado
  startTime String // HH:mm
  endTime   String // HH:mm
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId])
  @@index([dayOfWeek])
  @@map("staff_availability")
}

model MatchStaff {
  id         String    @id @default(uuid())
  matchId    String
  match      Match     @relation(fields: [matchId], references: [id])
  staffId    String
  staff      Staff     @relation(fields: [staffId], references: [id])
  role       String // referee, table_official, photographer
  status     String // assigned, applied, rejected
  assignedBy String?
  assignor   Profile?  @relation("AssignedBy", fields: [assignedBy], references: [id])
  assignedAt DateTime?
  createdAt  DateTime  @default(now())

  @@unique([matchId, role])
  @@index([matchId])
  @@index([staffId])
  @@map("match_staff")
}

// ============================================
// INSCRIPCIONES
// ============================================

model Registration {
  id               String    @id @default(uuid())
  teamId           String
  team             Team      @relation(fields: [teamId], references: [id])
  tournamentId     String
  tournament       Tournament @relation(fields: [tournamentId], references: [id])
  categoryId       String
  category         Category  @relation(fields: [categoryId], references: [id])
  status           String
  requestedBy      String
  requester        Profile   @relation("RequestedBy", fields: [requestedBy], references: [id])
  approvedBy       String?
  approver         Profile?  @relation("ApprovedBy", fields: [approvedBy], references: [id])
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  paymentProofUrl  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  payments Payment[]

  @@unique([teamId, tournamentId])
  @@index([teamId])
  @@index([tournamentId])
  @@index([categoryId])
  @@index([status])
  @@map("registrations")
}

// ============================================
// PAGOS
// ============================================

model Payment {
  id                String        @id @default(uuid())
  registrationId    String?
  registration      Registration? @relation(fields: [registrationId], references: [id])
  matchId           String?
  match             Match?        @relation(fields: [matchId], references: [id])
  profileId         String
  profile           Profile       @relation(fields: [profileId], references: [id])
  amount            Float
  currency          String        @default("ARS")
  method            String // mercadopago, cash, other
  status            String // pendiente, procesado, fallido
  providerPaymentId String?
  providerResponse  Json?
  processedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([registrationId])
  @@index([matchId])
  @@index([profileId])
  @@index([status])
  @@index([providerPaymentId])
  @@map("payments")
}

